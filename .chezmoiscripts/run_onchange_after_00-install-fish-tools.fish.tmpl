#!/usr/bin/env fish

# Re-run this script whenever the managed plugin list changes.
# fish_plugins_sha256={{ include "dot_config/private_fish/fish_plugins" | sha256sum }}

if not type -q fisher
    curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source
    fisher install jorgebucaran/fisher
end

fisher update
