# Environment needed in both interactive and non-interactive shells.
# Keep this section quiet so login shells and bash -lc can reuse it safely.

# rustup
if [[ -f "$HOME/.cargo/env" ]] ; then
	. "$HOME/.cargo/env"
fi

# uv, mise
case ":$PATH:" in
	*:"$HOME/.local/bin":*)
		;;
	*)
		export PATH="$HOME/.local/bin:$PATH"
		;;
esac

export EDITOR="nvim"
export VISUAL="nvim"

# Interactive-only configuration belongs below this point.
if [[ $- != *i* ]] ; then
	return
fi

if command -v mise >/dev/null 2>&1 ; then
	eval "$(mise activate bash)"
fi


